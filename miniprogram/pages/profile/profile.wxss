.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0 0;
  margin-bottom: 20rpx;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 0;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border);
}

.profile-meta {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
}

.profile-name-input {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  background: transparent;
  border: none;
  padding: 4rpx 0;
  width: 240rpx;
}

.profile-name-input::placeholder {
  color: var(--text-muted);
}

.profile-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: var(--text);
}

.setting-value {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.toggle-group {
  display: flex;
  gap: 0;
  border: 2rpx solid var(--primary);
  border-radius: 10rpx;
  overflow: hidden;
}

.toggle-btn {
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: white;
}

.toggle-btn.active {
  background: var(--primary);
  color: white;
  font-weight: 600;
}

.input-group {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.setting-input {
  width: 120rpx;
  text-align: right;
  font-size: 28rpx;
  color: var(--text);
  border-bottom: 2rpx solid var(--border);
  padding: 4rpx 0;
}

.setting-unit {
  font-size: 26rpx;
  color: var(--text-muted);
}

.btn-group {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-danger-outline {
  border-color: var(--danger);
  color: var(--danger);
}
