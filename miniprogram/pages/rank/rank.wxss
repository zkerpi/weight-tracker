.rank-tabs {
  display: flex;
  background: var(--card);
  border-radius: var(--radius);
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

.rank-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 10rpx;
  transition: all 0.2s;
}

.rank-tab.active {
  background: var(--primary);
  color: white;
  font-weight: 600;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
}

.rank-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.rank-medal {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.rank-medal-top {
  font-size: 48rpx;
  width: 60rpx;
}

/* 第一名 */
.rank-item-first {
  background: linear-gradient(135deg, #fef9c3 0%, #fde68a 100%);
  border: 2rpx solid #f59e0b;
}

.rank-item-first .rank-name {
  color: #92400e;
}

.rank-item-first .rank-value {
  color: #f59e0b;
}

.rank-number {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-muted);
  width: 48rpx;
  text-align: center;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.rank-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-weight {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

.rank-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.rank-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.rank-value.streak-value {
  color: #f59e0b;
}

.rank-unit {
  font-size: 24rpx;
  color: var(--text-muted);
}

.checkin-badge {
  margin-top: 2rpx;
}

/* 第二名 */
.rank-item-second {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  border: 2rpx solid #cbd5e1;
}

.rank-item-second .rank-name {
  color: #475569;
}

/* 第三名 */
.rank-item-third {
  background: linear-gradient(135deg, #fafaf9 0%, #e7e5e4 100%);
  border: 2rpx solid #d6d3d1;
}

.rank-item-third .rank-name {
  color: #78716c;
}

/* 骨架屏 */
.skeleton-circle {
  width: 48rpx;
  height: 36rpx;
  background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  flex-shrink: 0;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-name {
  width: 120rpx;
  margin-bottom: 8rpx;
}

.skeleton-curweight {
  width: 180rpx;
}

.skeleton-value {
  width: 100rpx;
  height: 32rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
