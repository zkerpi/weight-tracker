<view class="page">
  <!-- 每日寄语 -->
  <view class="quote-card">
    <text class="quote-text">"{{dailyQuote}}"</text>
  </view>

  <!-- 今日体重 -->
  <view class="card weight-card">
    <view class="card-row">
      <text class="section-title">今日体重</text>
      <view class="date-badge">{{todayDate}}</view>
    </view>
    <view class="weight-display" wx:if="{{todayWeight}}">
      <text class="weight-number">{{todayWeight}}</text>
      <text class="weight-unit">{{unitLabel}}</text>
    </view>
    <view class="weight-empty" wx:else>
      <text class="weight-empty-text">今天还没打卡</text>
    </view>
    <button class="btn-primary" bindtap="goRecord">
      <text wx:if="{{todayWeight}}">修改记录</text>
      <text wx:else>开始打卡</text>
    </button>
  </view>

  <!-- 统计卡片 -->
  <view class="card">
    <view class="stats-row">
      <view class="stats-col">
        <text class="stats-num {{totalChange >= 0 ? 'text-primary' : 'text-danger'}}">{{changeDisplay || '-'}}{{unitLabel}}</text>
        <text class="stats-label">{{goalType === 'gain' ? '已增' : '已减'}}</text>
      </view>
      <view class="stats-col">
        <text class="stats-num">{{streak || 0}} 天</text>
        <text class="stats-label">连续打卡</text>
      </view>
      <view class="stats-col stats-col-clickable" bindtap="goHistory">
        <text class="stats-num">{{totalDays || 0}} 天</text>
        <text class="stats-label">共打卡 ›</text>
      </view>
    </view>
  </view>

  <!-- 周/月统计 -->
  <view class="card" wx:if="{{weekStats && weekStats.avg}}">
    <view class="summary-tabs">
      <view class="summary-tab active">
        <text class="summary-tab-title">本周</text>
        <view class="summary-row">
          <text class="summary-label">平均</text>
          <text class="summary-value">{{weekStats.avg}} {{unitLabel}}</text>
        </view>
        <view class="summary-row">
          <text class="summary-label">变化</text>
          <text class="summary-change {{weekStats.isUp ? 'text-danger' : ''}} {{weekStats.isDown ? 'text-primary' : ''}}">{{weekStats.change}} {{unitLabel}}</text>
        </view>
      </view>
      <view class="summary-tab">
        <text class="summary-tab-title">本月</text>
        <view class="summary-row">
          <text class="summary-label">平均</text>
          <text class="summary-value">{{monthStats.avg}} {{unitLabel}}</text>
        </view>
        <view class="summary-row">
          <text class="summary-label">变化</text>
          <text class="summary-change {{monthStats.isUp ? 'text-danger' : ''}} {{monthStats.isDown ? 'text-primary' : ''}}">{{monthStats.change}} {{unitLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 趋势图 -->
  <view class="card">
    <view class="card-row">
      <text class="section-title">体重趋势</text>
      <picker mode="selector" range="{{chartRanges}}" value="{{chartRangeIndex}}" bindchange="onChartRangeChange">
        <view class="picker-btn">{{chartRanges[chartRangeIndex]}} ▾</view>
      </picker>
    </view>
    <trend-chart
      wx:if="{{chartData.length > 0}}"
      data="{{chartData}}"
      goalWeight="{{displayGoalWeight}}"
      unitLabel="{{unitLabel}}"
      goalType="{{goalType}}"
    ></trend-chart>
    <view class="empty-state" wx:else>
      <text>暂无数据</text>
      <text>开始打卡后将显示趋势图</text>
    </view>
  </view>
</view>
