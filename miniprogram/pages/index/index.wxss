.welcome-card {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: white;
}

.welcome-card .section-title {
  color: rgba(255,255,255,0.9);
}

.welcome-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
}

.welcome-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.welcome-name {
  font-size: 34rpx;
  font-weight: 700;
}

.welcome-sub {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.progress-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.progress-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.progress-value {
  font-size: 26rpx;
  font-weight: 600;
}

.progress-bar-bg {
  height: 10rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: white;
  border-radius: 5rpx;
  transition: width 0.3s;
}

.quote-card {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: var(--radius);
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.quote-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.95);
  line-height: 1.6;
}

.weight-card {
  text-align: center;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-badge {
  font-size: 24rpx;
  color: var(--text-muted);
  background: var(--bg);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.weight-display {
  padding: 30rpx 0;
}

.weight-number {
  font-size: 80rpx;
  font-weight: 800;
  color: var(--primary);
}

.weight-unit {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.weight-empty {
  padding: 40rpx 0;
}

.weight-empty-text {
  font-size: 30rpx;
  color: var(--text-muted);
}

.text-primary {
  color: var(--primary) !important;
}

.text-danger {
  color: var(--danger) !important;
}

.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 10rpx;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stats-col {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-right: 1rpx solid var(--border);
}

.stats-col:last-child {
  border-right: none;
}

.stats-col-clickable {
  cursor: pointer;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text);
  display: block;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}

.picker-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 6rpx 16rpx;
  background: var(--bg);
  border-radius: 20rpx;
}

/* 图表底部周/月统计 */
.chart-stats {
  display: flex;
  gap: 2rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.chart-stats-col {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 6rpx 0;
}

.chart-stats-col:first-child {
  border-right: 1rpx solid var(--border);
}

.chart-stats-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.chart-stats-value {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
}

.chart-stats-change {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
}
