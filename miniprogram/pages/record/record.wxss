.record-page {
  display: flex;
  flex-direction: column;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.record-date {
  font-size: 26rpx;
  color: var(--text-muted);
}

.weight-input-area {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.weight-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.weight-input {
  font-size: 48rpx;
  font-weight: 600;
  text-align: center;
  width: 200rpx;
  height: 70rpx;
  color: var(--text);
  border-bottom: 4rpx solid var(--primary);
}

.weight-input-unit {
  font-size: 36rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.weight-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

.quick-weights {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}

.quick-weight-btn {
  padding: 12rpx 28rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.quick-weight-btn.selected {
  background: var(--primary-light);
  border-color: var(--primary);
  color: var(--primary);
  font-weight: 600;
}

.quick-weight-btn:active {
  opacity: 0.7;
}

.note-input-area {
  margin-bottom: 20rpx;
  text-align: center;
}

.note-input {
  width: 70%;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid var(--border);
  display: block;
  margin: 0 auto;
}

.weight-compare {
  text-align: center;
  margin-top: 20rpx;
  font-size: 28rpx;
}

.compare-up {
  color: var(--danger);
}

.compare-down {
  color: var(--primary);
}

.compare-same {
  color: var(--text-muted);
}

/* 分享卡片 */
.share-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.share-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 560rpx;
  text-align: center;
}

.share-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
  margin-bottom: 20rpx;
}

.share-weight {
  font-size: 80rpx;
  font-weight: 800;
  color: var(--text);
  display: block;
  line-height: 1.2;
}

.share-date {
  font-size: 26rpx;
  color: var(--text-muted);
  display: block;
  margin: 12rpx 0 30rpx;
}

.share-msg {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 40rpx;
}

.share-skip {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  padding: 10rpx;
}
