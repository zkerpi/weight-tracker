<view class="page">
  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="skeleton-item" wx:for="{{5}}" wx:key="*this">
      <view class="skeleton-line skeleton-date"></view>
      <view class="skeleton-line skeleton-weight"></view>
      <view class="skeleton-line skeleton-change"></view>
    </view>
  </view>

  <block wx:else>
    <!-- 补签提醒 -->
    <view wx:if="{{gaps.length > 0}}" class="backfill-banner">
      <text class="backfill-title">有 {{gaps.length}} 天未打卡</text>
      <view class="backfill-list">
        <view class="backfill-item" wx:for="{{gaps}}" wx:key="*this" bindtap="goBackfill" data-date="{{item}}">
          <text class="backfill-date">{{item}}</text>
          <text class="backfill-action">去补签 ›</text>
        </view>
      </view>
    </view>

    <!-- 记录列表 -->
    <view wx:if="{{records.length > 0}}" class="history-list">
      <view class="history-item" wx:for="{{records}}" wx:key="_id" data-id="{{item._id}}" data-date="{{item.date}}" bindlongpress="onDeleteRecord">
        <view class="history-left">
          <text class="history-date">{{item.date}}</text>
          <text class="history-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
        <view class="history-right">
          <text class="history-weight">{{item.weight}} {{unitLabel}}</text>
          <text class="history-diff {{item.diffUp ? 'diff-up' : ''}} {{item.diffDown ? 'diff-down' : ''}}">
            {{item.diffFormatted}}
          </text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{records.length === 0}}" class="empty-state">
      <text>暂无记录</text>
      <text>开始打卡后将显示在这里</text>
    </view>
  </block>
</view>
