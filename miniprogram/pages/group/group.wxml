<view class="page">
  <!-- 创建群组 -->
  <view class="card" wx:if="{{!myGroup}}">
    <text class="section-title">创建群组</text>
    <view class="form-row">
      <input class="input-field" placeholder="输入群组名称" value="{{groupName}}" bindinput="onGroupNameInput" maxlength="20"></input>
    </view>
    <button class="btn-primary" bindtap="createGroup" disabled="{{!groupNameValid}}">创建群组</button>
  </view>

  <!-- 加入群组 -->
  <view class="card" wx:if="{{!myGroup}}">
    <text class="section-title">加入群组</text>
    <view class="form-row">
      <input class="input-field code-input" placeholder="输入4位邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" maxlength="4"></input>
    </view>
    <button class="btn-outline" bindtap="joinGroup" disabled="{{!inviteCodeValid}}">加入群组</button>
  </view>

  <!-- 我的群组 -->
  <view class="card" wx:if="{{myGroup}}">
    <text class="section-title">我的群组</text>
    <view class="my-group-info">
      <view class="group-detail-row">
        <text class="group-detail-label">群组名称</text>
        <view wx:if="{{editingName}}" class="edit-name-row">
          <input class="input-field edit-name-input" placeholder="输入群组名称" value="{{editNameValue}}" bindinput="onEditNameInput" maxlength="20"></input>
          <view class="edit-name-actions">
            <text class="edit-name-btn save" bindtap="saveGroupName">保存</text>
            <text class="edit-name-btn cancel" bindtap="cancelEditName">取消</text>
          </view>
        </view>
        <view wx:else class="group-detail-value-row">
          <text class="group-detail-value">{{myGroup.groupName}}</text>
          <text wx:if="{{isCreator}}" class="edit-name-icon" bindtap="startEditName">✎</text>
        </view>
      </view>
      <view class="group-detail-row">
        <text class="group-detail-label">邀请码</text>
        <view class="invite-code-box" bindtap="copyInviteCode">
          <text class="invite-code">{{myGroup.inviteCode}}</text>
          <text class="copy-hint">点击复制</text>
        </view>
      </view>
      <view class="group-detail-row">
        <text class="group-detail-label">成员数</text>
        <text class="group-detail-value">{{myGroup.members ? myGroup.members.length : 0}} 人</text>
      </view>
    </view>

    <!-- 成员列表 -->
    <view wx:if="{{members.length > 0}}" class="member-section">
      <text class="member-section-title">群组成员</text>
      <view class="member-list">
        <view class="member-item" wx:for="{{members}}" wx:key="openId">
          <image class="member-avatar" src="{{item.avatarUrl || '/images/profile.png'}}" mode="aspectFill"></image>
          <text class="member-name">{{item.nickName || '用户'}}</text>
          <text wx:if="{{item.openId === myGroup.creator}}" class="creator-badge">群主</text>
          <text wx:if="{{isCreator && item.openId !== myOpenId}}" class="kick-btn" bindtap="kickMember" data-openid="{{item.openId}}" data-name="{{item.nickName}}">踢出</text>
        </view>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn-primary" open-type="share">邀请好友</button>
      <button wx:if="{{isCreator}}" class="btn-outline btn-danger-outline" bindtap="disbandGroup">解散群组</button>
      <button wx:else class="btn-outline btn-danger-outline" bindtap="leaveGroup">退出群组</button>
    </view>
  </view>
</view>
