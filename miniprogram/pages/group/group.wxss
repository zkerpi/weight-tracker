.form-row {
  margin-bottom: 20rpx;
}

.code-input {
  text-align: center;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  text-transform: uppercase;
}

.my-group-info {
  margin-bottom: 16rpx;
}

.group-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.group-detail-row:last-child {
  border-bottom: none;
}

.group-detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.group-detail-value {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.invite-code-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--primary-light);
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}

.invite-code {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 6rpx;
}

.copy-hint {
  font-size: 22rpx;
  color: var(--primary);
  opacity: 0.7;
}

.btn-danger-outline {
  border-color: var(--danger);
  color: var(--danger);
}

.btn-group {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 成员列表 */
.member-section {
  margin: 16rpx 0;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.member-section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 100rpx;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--border);
}

.member-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100rpx;
}

.creator-badge {
  font-size: 18rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.kick-btn {
  font-size: 20rpx;
  color: var(--danger);
  padding: 4rpx 10rpx;
  border: 1rpx solid var(--danger);
  border-radius: 8rpx;
}

.kick-btn:active {
  opacity: 0.6;
}

.group-detail-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.edit-name-icon {
  font-size: 28rpx;
  color: var(--primary);
  padding: 4rpx;
}

.edit-name-icon:active {
  opacity: 0.6;
}

.edit-name-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-end;
}

.edit-name-input {
  text-align: right;
  font-size: 28rpx;
  width: 300rpx;
}

.edit-name-actions {
  display: flex;
  gap: 16rpx;
}

.edit-name-btn {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.edit-name-btn.save {
  color: var(--primary);
  background: var(--primary-light);
}

.edit-name-btn.cancel {
  color: var(--text-muted);
  background: var(--bg);
}
