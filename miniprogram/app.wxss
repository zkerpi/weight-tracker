page {
  --primary: #10b981;
  --primary-light: #d1fae5;
  --primary-dark: #059669;
  --bg: #f8fafc;
  --card: #ffffff;
  --text: #1e293b;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --border: #e2e8f0;
  --danger: #ef4444;
  --warning: #f59e0b;
  --success: #10b981;
  --radius: 12px;
  --shadow: 0 2px 8px rgba(0,0,0,0.06);
  box-sizing: border-box;
  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
}

.page {
  min-height: 100vh;
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--radius);
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid var(--primary);
  border-radius: var(--radius);
}

.btn-outline:active {
  background: var(--primary-light);
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f1f5f9;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--primary);
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-item {
  background: var(--bg);
  border-radius: 10rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  color: var(--text-muted);
}

.empty-state text {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
}

.badge {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-success {
  background: #d1fae5;
  color: #059669;
}

.badge-warning {
  background: #fef3c7;
  color: #d97706;
}

.badge-danger {
  background: #fce4ec;
  color: #e53935;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: var(--text);
}
